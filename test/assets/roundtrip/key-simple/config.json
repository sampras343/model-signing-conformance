{
  "description": "Basic key sign-then-verify roundtrip on a simple two-file model",
  "method": "key",
  "model": "models/simple",
  "expected_signed_files": [
    "signme-1",
    "signme-2"
  ],
  "sign": {
    "private_key": "keys/certificate/signing-key.pem"
  },
  "verify": {
    "public_key": "keys/certificate/signing-key-pub.pem",
    "ignore_paths": [
      "ignore-me"
    ]
  }
}
