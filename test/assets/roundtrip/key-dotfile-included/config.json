{
  "description": "Verifies non-git dotfiles (.config, .env.example) ARE signed and not mistakenly excluded",
  "method": "key",
  "model": "models/with-dotfiles",
  "expected_signed_files": [
    ".config",
    ".env.example",
    "model.bin"
  ],
  "sign": {
    "private_key": "keys/certificate/signing-key.pem"
  },
  "verify": {
    "public_key": "keys/certificate/signing-key-pub.pem"
  }
}
