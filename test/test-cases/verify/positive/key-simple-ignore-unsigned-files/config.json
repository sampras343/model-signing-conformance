{
  "description": "Verifies --ignore-unsigned-files allows extra unsigned files to pass verification",
  "method": "key",
  "model": "models/simple",
  "model_modifications": {
    "inject": {
      "extra.bin": "extra file added after signing\n"
    }
  },
  "verify": {
    "public_key": "keys/certificate/signing-key-pub.pem",
    "ignore_paths": [
      "ignore-me"
    ],
    "ignore_unsigned_files": true
  }
}
