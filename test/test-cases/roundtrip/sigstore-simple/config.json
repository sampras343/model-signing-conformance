{
  "description": "Keyless sigstore sign-then-verify on simple model (§4.1 — requires CI OIDC token)",
  "method": "sigstore",
  "model": "models/simple",
  "requires_ci": true,
  "sign": {
    "identity_token_env": "SIGSTORE_ID_TOKEN"
  },
  "verify": {
    "identity": "${SIGSTORE_IDENTITY}",
    "identity_provider": "https://token.actions.githubusercontent.com",
    "ignore_paths": ["ignore-me"]
  },
  "expected_signed_files": ["signme-1", "signme-2"]
}
