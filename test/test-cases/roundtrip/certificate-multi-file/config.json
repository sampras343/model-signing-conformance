{
  "description": "Certificate roundtrip on a model with subdirectories",
  "method": "certificate",
  "model": "models/multi-file",
  "expected_signed_files": [
    "config.json",
    "subdir/adapter.bin",
    "weights.bin"
  ],
  "sign": {
    "private_key": "keys/certificate/signing-key.pem",
    "signing_cert": "keys/certificate/signing-key-cert.pem",
    "cert_chain": [
      "keys/certificate/int-ca-cert.pem"
    ]
  },
  "verify": {
    "cert_chain": [
      "keys/certificate/ca-cert.pem"
    ]
  }
}
