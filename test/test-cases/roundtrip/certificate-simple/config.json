{
  "description": "Certificate sign-then-verify roundtrip using 3-level PKI chain",
  "method": "certificate",
  "model": "models/simple",
  "expected_signed_files": [
    "signme-1",
    "signme-2"
  ],
  "sign": {
    "private_key": "keys/certificate/signing-key.pem",
    "signing_cert": "keys/certificate/signing-key-cert.pem",
    "cert_chain": [
      "keys/certificate/int-ca-cert.pem"
    ]
  },
  "verify": {
    "ignore_paths": [
      "ignore-me"
    ],
    "cert_chain": [
      "keys/certificate/ca-cert.pem"
    ]
  }
}
