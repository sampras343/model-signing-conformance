{
  "description": "Certificate roundtrip with a self-signed certificate (no intermediate CA)",
  "method": "certificate",
  "model": "models/simple",
  "expected_signed_files": [
    "signme-1",
    "signme-2"
  ],
  "sign": {
    "private_key": "keys/self-signed/signing-key.pem",
    "signing_cert": "keys/self-signed/signing-cert.pem",
    "cert_chain": [
      "keys/self-signed/signing-cert.pem"
    ]
  },
  "verify": {
    "ignore_paths": [
      "ignore-me"
    ],
    "cert_chain": [
      "keys/self-signed/signing-cert.pem"
    ]
  }
}
