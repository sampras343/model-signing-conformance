{
  "description": "Signing and verification of models with spaces and special characters in paths",
  "method": "key",
  "model": "models/special-chars",
  "expected_signed_files": [
    "file (copy).bin",
    "normal.bin",
    "path with spaces/model.bin"
  ],
  "sign": {
    "private_key": "keys/certificate/signing-key.pem"
  },
  "verify": {
    "public_key": "keys/certificate/signing-key-pub.pem"
  }
}
